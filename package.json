{
  "name": "verixa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "worker:dev": "wrangler dev --config worker-api/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker-api/wrangler.toml",
    "worker:secret:openai": "wrangler secret put OPENAI_API_KEY --config worker-api/wrangler.toml",
    "worker:secret:n8n": "wrangler secret put N8N_WEBHOOK_URL --config worker-api/wrangler.toml"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "motion": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^4.5.14",
    "wrangler": "^4.77.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.0"
  }
}
